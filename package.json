{
  "name": "convex-llm-analytics",
  "description": "A Convex component scaffold for LLM analytics.",
  "repository": "github:beckthemaster/convex-llm-analytics",
  "homepage": "https://github.com/beckthemaster/convex-llm-analytics#readme",
  "bugs": {
    "url": "https://github.com/beckthemaster/convex-llm-analytics/issues"
  },
  "version": "0.1.0",
  "license": "Apache-2.0",
  "packageManager": "bun@1.3.11",
  "keywords": [
    "convex",
    "component"
  ],
  "type": "module",
  "scripts": {
    "generate": "mkdir -p convex && convex codegen --component-dir ./src/component",
    "codegen": "bun run generate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:once": "vitest run",
    "typecheck": "tsc --noEmit --project ./tsconfig.typecheck.json",
    "check": "bun run format && bun run lint && bun run typecheck && bun run test",
    "build": "tsc --project ./tsconfig.build.json"
  },
  "files": [
    "dist",
    "src/component"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./_generated/component.js": {
      "types": "./dist/component/_generated/component.d.ts"
    },
    "./_generated/component": {
      "types": "./dist/component/_generated/component.d.ts"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    }
  },
  "peerDependencies": {
    "convex": "^1.33.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@edge-runtime/vm": "^5.0.0",
    "convex": "1.33.0",
    "convex-test": "^0.0.41",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.1.0"
  },
  "types": "./dist/client/index.d.ts",
  "module": "./dist/client/index.js"
}
