{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "lib": ["ES2023"],
    "forceConsistentCasingInFileNames": true,
    "noErrorTruncation": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "composite": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": ["./src/**/*"]
}
